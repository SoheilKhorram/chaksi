datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String           @id @default(uuid())
  displayId        String           @unique
  username         String           @unique
  password         String
  avatar           String           @default("cat.png")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  padelSessions    PadelSession[]
  padelSettings    PadelSettings?
  sentRequests     PartnerRequest[] @relation("SentRequests")
  receivedRequests PartnerRequest[] @relation("ReceivedRequests")
  sentSharedSessions     SharedSession[]  @relation("SentSharedSessions")
  receivedSharedSessions SharedSession[]  @relation("ReceivedSharedSessions")
}

model PartnerRequest {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User     @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  status      String   // "PENDING" | "ACCEPTED"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([senderId, receiverId])
}

model PadelSession {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       DateTime @default(now())
  duration   Float    // E.g., 1.5 for 1.5h
  players    String   // Opponents / partners
  type       String   // "game" | "training"
  price      Float    // Price of this session itself
  extraItems Json     // Array of { name: string, price: number }
  totalCost  Float    // Price + sum of extraItems price
  isPaid     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PadelSettings {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gamePrice     Float    @default(250000) // Default price per hour/session for games
  trainingPrice Float    @default(800000) // Default price per hour/session for training
  sendGameToPartner     Boolean  @default(false)
  sendTrainingToPartner Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SharedSession {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("SentSharedSessions", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("ReceivedSharedSessions", fields: [receiverId], references: [id], onDelete: Cascade)
  date       DateTime
  duration   Float
  players    String
  type       String   // "game" | "training"
  price      Float
  extraItems Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
